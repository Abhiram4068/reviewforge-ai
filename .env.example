# ==========================================
# ReviewForge AI Environment Configuration
# ==========================================

# --- Backend Configuration ---
# Database connection string. Use postgresql+psycopg2 for PostgreSQL.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/reviewforge
# DATABASE_URL=sqlite:///./reviewforge.db

# Redis connection string for Celery broker & backend
REDIS_URL=redis://localhost:6379/0

# JWT Auth Secret & Algorithm
JWT_SECRET=generate_a_secure_random_hex_key_here
JWT_ALGORITHM=HS256

# GitHub App Configuration (obtain from GitHub developer portal)
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_key

# AI Foundation Keys
# Anthropic Claude API Key
ANTHROPIC_API_KEY=sk-ant-api03-...
# Qdrant Vector DB connection configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_if_applicable

# --- Frontend Configuration ---
# API endpoint for Vite app proxying/direct requests
VITE_API_URL=http://localhost:8000/api/v1
